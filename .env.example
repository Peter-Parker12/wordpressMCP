# ─── WordPress ────────────────────────────────────────────────────────────────

# Your WordPress site URL — no trailing slash
WP_URL=https://your-wordpress-site.com

# Your WordPress login username (not email, not display name)
WP_USERNAME=your_username

# Application password — generate at:
# WP Admin → Users → Your Profile → scroll to "Application Passwords" → Add New
# Copy the generated password exactly (spaces are fine, or remove them)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Claude OAuth Credentials ─────────────────────────────────────────────────
#
# These identify Claude to your MCP server during the OAuth flow.
# You choose CLAUDE_CLIENT_ID (any readable string is fine).
# Generate CLAUDE_CLIENT_SECRET with:  openssl rand -hex 32
#
# Enter the SAME values in Claude's connector settings:
#   "OAuth Client ID"     → value of CLAUDE_CLIENT_ID
#   "OAuth Client Secret" → value of CLAUDE_CLIENT_SECRET

CLAUDE_CLIENT_ID=wordpress-mcp
CLAUDE_CLIENT_SECRET=replace-with-output-of-openssl-rand-hex-32

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the server listens on inside Docker.
# Must match what your Cloudflare Tunnel / nginx proxy points to.
PORT=9809

{
  "name": "WordPress MCP Server",
  "description": "Local MCP server exposing WordPress blog creation and media upload operations for Claude.",
  "version": "0.1.0",
  "protocol": "mcp",
  "endpoints": [
    {
      "path": "/health",
      "method": "GET",
      "description": "Health check endpoint."
    },
    {
      "path": "/create-post",
      "method": "POST",
      "description": "Create a new WordPress post.",
      "parameters": {
        "title": "string",
        "content": "string",
        "status": "string (optional, default draft)",
        "excerpt": "string (optional)",
        "categories": "array of category IDs (optional)",
        "tags": "array of tag IDs (optional)",
        "featured_media": "media ID (optional)"
      }
    },
    {
      "path": "/update-post",
      "method": "POST",
      "description": "Update an existing WordPress post.",
      "parameters": {
        "postId": "integer",
        "title": "string (optional)",
        "content": "string (optional)",
        "status": "string (optional)",
        "excerpt": "string (optional)",
        "categories": "array of category IDs (optional)",
        "tags": "array of tag IDs (optional)",
        "featured_media": "media ID (optional)"
      }
    },
    {
      "path": "/upload-image",
      "method": "POST",
      "description": "Upload an image to WordPress media library.",
      "parameters": {
        "imageUrl": "string (URL to fetch image from) or imageBase64: string",
        "fileName": "string (optional filename)",
        "mimeType": "string (optional)"
      }
    },
    {
      "path": "/set-featured-image",
      "method": "POST",
      "description": "Set a post's featured image using a media ID.",
      "parameters": {
        "postId": "integer",
        "mediaId": "integer"
      }
    },
    {
      "path": "/posts",
      "method": "GET",
      "description": "List WordPress posts with optional query filters.",
      "parameters": {
        "page": "integer (optional)",
        "per_page": "integer (optional)",
        "status": "string (optional)",
        "search": "string (optional)"
      }
    },
    {
      "path": "/posts/{postId}",
      "method": "GET",
      "description": "Fetch a single WordPress post by ID.",
      "parameters": {
        "postId": "integer"
      }
    },
    {
      "path": "/create-post-with-image",
      "method": "POST",
      "description": "Create a post and upload an image to use as featured media.",
      "parameters": {
        "title": "string",
        "content": "string",
        "imageUrl": "string (optional)",
        "imageBase64": "string (optional)",
        "fileName": "string (optional)",
        "mimeType": "string (optional)",
        "status": "string (optional, default draft)",
        "excerpt": "string (optional)",
        "categories": "array of category IDs (optional)",
        "tags": "array of tag IDs (optional)"
      }
    },
    {
      "path": "/.well-known/mcp/register",
      "method": "POST",
      "description": "Connector registration endpoint (compatibility)."
    },
    {
      "path": "/register",
      "method": "POST",
      "description": "Connector registration endpoint (compatibility)."
    },
    {
      "path": "/oauth/token",
      "method": "POST",
      "description": "OAuth token endpoint (compatibility)."
    },
    {
      "path": "/oauth/introspect",
      "method": "POST",
      "description": "OAuth introspection endpoint (compatibility)."
    },
    {
      "path": "/oauth/revoke",
      "method": "POST",
      "description": "OAuth token revocation endpoint (compatibility)."
    },
    {
      "path": "/manifest",
      "method": "GET",
      "description": "Fetch the MCP manifest."
    },
    {
      "path": "/.well-known/jwks.json",
      "method": "GET",
      "description": "JWKS endpoint for OAuth compatibility."
    },
    {
      "path": "/authorize",
      "method": "GET",
      "description": "OAuth authorization endpoint (compatibility, raw path used by Claude)."
    },
    {
      "path": "/oauth/authorize",
      "method": "GET",
      "description": "OAuth authorization endpoint (compatibility)."
    },
    {
      "path": "/authorized",
      "method": "GET",
      "description": "OAuth authorization callback endpoint (compatibility)."
    }
  ]
}

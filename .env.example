# ─── WordPress ────────────────────────────────────────────────────────────────

# Your WordPress site URL — no trailing slash
WP_URL=https://your-wordpress-site.com

# Your WordPress login username (not email, not display name)
WP_USERNAME=your_username

# Application password — generate at:
# WP Admin → Users → Your Profile → scroll to "Application Passwords" → Add New
# Copy the generated password exactly (spaces are fine, or remove them)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Claude OAuth Client ───────────────────────────────────────────────────────
#
# These two values identify Claude to your server.
# You choose them — any string works.
# Enter the SAME values in Claude's connector settings when prompted.
#
# CLAUDE_CLIENT_ID   → paste into "OAuth Client ID" in Claude connector settings
# CLAUDE_CLIENT_SECRET → paste into "OAuth Client Secret" in Claude connector settings

CLAUDE_CLIENT_ID=wordpress-mcp
CLAUDE_CLIENT_SECRET=    # generate with: openssl rand -hex 32

# ─── MCP Bearer Token ─────────────────────────────────────────────────────────
#
# Static token Claude sends on every MCP request.
# Generate with: openssl rand -hex 32
# Enter the SAME value in Claude's connector settings under "API Key" or "Bearer Token"

MCP_TOKEN=    # generate with: openssl rand -hex 32

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the server listens on inside Docker.
# Must match what your Cloudflare Tunnel / nginx proxy points to.
PORT=9809
